{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm --workspace @gta-rp/server run build"
  },
  "deploy": {
    "startCommand": "npm --workspace @gta-rp/server run start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/health"
  },
  "plugins": [
    {
      "plugin": "postgresql",
      "options": {
        "version": "16"
      }
    }
  ]
}
