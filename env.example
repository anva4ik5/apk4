# Railway Environment Variables
# Эти переменные автоматически создаются на Railway

# Database (автоматически создается Railway PostgreSQL плагином)
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Server Configuration
PORT=3000
NODE_ENV=production

# Security (нужно задать вручную в Railway)
JWT_SECRET=your-secret-key-minimum-32-characters-long
ADMIN_TOKEN=your-admin-token

# CORS
CORS_ORIGINS=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=20

# Proxy
TRUST_PROXY=true
